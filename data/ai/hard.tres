[gd_resource type="Resource" script_class="AIProfile" load_steps=2 format=3]

[ext_resource type="Script" path="res://ai/ai_profile.gd" id="1"]

; Difficult. Weights set by the DF4 AI-vs-AI ladder, not by taste — see
; docs/difficulty_check.md for the measurements behind each one.
;
; threat_aversion is deliberately small: the penalty is scaled by the exposed
; unit's cost, so on a contested front the incoming total saturates and anything
; above ~0.15 stops the AI attacking at all (0.5 lost 88% of its games).
;
; advance_threat_tiles is the same caution on the advance path, and it is a
; separate dial because that path scores in tiles rather than in value —
; threat_aversion's ladder-safe 0.1 is worth a hundredth of a tile there and
; could only ever break ties, which left the tier's flagship "refuses a kill
; zone" inert where nobody was attacking. 2.0 buys two tiles of retreat from a
; shot that would kill outright, and proportionally less from one that would not;
; below ~1.6 a healthy unit cannot buy even one against a plain artillery shot,
; so that is the floor. A starting value: it has not been through the ladder yet.
;
; focus_fire_bonus ships at 0. The capability is implemented and tested, but it
; measured negative in every shape tried — the planner already re-plans after
; each command, so a wounded target's kill is visible to the next attacker for
; free, and biasing the *first* shot toward a gang-up pulls it off its own best
; trade. Left switched off rather than deleted: zeroing a misbehaving smart is
; the plan's own remedy, and the ladder can re-test it in one edit.
[resource]
script = ExtResource("1")
kill_bonus = 1.8
counter_weight = 0.5
capture_score = 900.0
hq_capture_multiplier = 3.0
capture_progress_bonus = 45.0
step_cost_penalty = 4.0
retreat_hp = 45
min_useful_score = 40.0
advance_score = 1.0
build_priority = Array[StringName]([&"md_tank", &"tank", &"artillery", &"mech"])
capture_unit_target = 3
threat_aversion = 0.1
advance_threat_tiles = 2.0
focus_fire_bonus = 0.0
build_reactivity = 0.6
