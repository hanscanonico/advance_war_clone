# Godot
.godot/

# Vendored engine binary (see README for setup). No trailing slash: a git
# worktree shares no ignored files with the main checkout, so the usual fix is
# to symlink bin/ across — and `bin/` would not match a symlink named `bin`.
bin

# macOS
.DS_Store

# Local verification artifacts
screenshot*.png
screenshot*.png.import

# Balance runner output (tools/run_commander_balance.gd). The committed artifacts
# of a balance pass are tuned data/commanders/*.tres and docs/commander_balance.md,
# never the generated CSV/JSON.
reports/

# Agent scratch space. .claude/worktrees holds nested checkouts of this repo,
# which git would otherwise offer to commit as embedded repositories.
.claude/
