# Godot
.godot/

# Vendored engine binary (see README for setup). No trailing slash: a git
# worktree shares no ignored files with the main checkout, so the usual fix is
# to symlink bin/ across — and `bin/` would not match a symlink named `bin`.
bin

# macOS
.DS_Store

# Local verification artifacts
screenshot*.png
screenshot*.png.import

# Balance runner output (tools/run_commander_balance.gd). The committed artifacts
# of a balance pass are tuned data/commanders/*.tres and docs/commander_balance.md,
# never the generated CSV/JSON. `reports/*` rather than `reports/`: git will not
# look inside an excluded directory, so the marker below could not be re-included.
reports/*
# The one exception, and the reason the directory is tracked at all: it tells the
# engine not to import a report as game data. See reports/.gdignore.
!reports/.gdignore

# Agent scratch space. .claude/worktrees holds nested checkouts of this repo,
# which git would otherwise offer to commit as embedded repositories.
.claude/

# Lavish review artifacts — in-progress plans and the screenshots they cite are
# scratch by default. The designs of record CLAUDE.md points at are already
# tracked and stay that way: ignoring a path git already tracks changes nothing.
# A new plan worth keeping is promoted with `git add -f .lavish/<name>.html`.
.lavish/
