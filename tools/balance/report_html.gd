class_name BalanceReportHtml
extends RefCounted
## Draws a Balance Lab run: the win-rate table as bars against the standing
## bands, per-board first-seat bias, and the funds / army-value curves the
## timeline promises — the numbers a spreadsheet makes you squint at.
##
## Two rules it is held to (plan BS4):
##
##  1. **It computes nothing.** Every figure is read from summary.json or
##     timeline.csv. The report can therefore be checked against the raw files by
##     hand, and it can never disagree with them.
##  2. **It is self-contained.** One file, inline CSS, inline SVG, no script, no
##     CDN, no server — it opens off disk next to the CSVs it renders, and it is
##     gitignored with the rest of the report.
##
## Node-free, like everything else here.

## How many per-match curves to draw. A full sweep is hundreds of matches and a
## wall of sparklines reads as noise; the count that was dropped is printed on
## the page rather than silently trimmed.
const MAX_CURVES := 12

const STYLE := """
:root { color-scheme: dark; }
* { box-sizing: border-box; }
body {
  margin: 0; padding: 2rem 1.5rem 4rem;
  background: #0f1720; color: #d7e3ee;
  font: 15px/1.6 ui-sans-serif, -apple-system, "Segoe UI", Helvetica, sans-serif;
}
main { max-width: 1080px; margin: 0 auto; }
h1 { font-size: 1.6rem; margin: 0 0 .25rem; letter-spacing: -.01em; }
h2 { font-size: 1.05rem; margin: 2.5rem 0 .75rem; text-transform: uppercase;
     letter-spacing: .1em; color: #7fa7c8; font-weight: 700; }
.sub { color: #8ba3ba; margin: 0 0 1.5rem; }
.cards { display: flex; flex-wrap: wrap; gap: .75rem; }
.card { background: #16212d; border: 1px solid #23313f; border-radius: .5rem;
        padding: .7rem 1rem; min-width: 8.5rem; }
.card b { display: block; font-size: 1.5rem; font-variant-numeric: tabular-nums; }
.card span { color: #8ba3ba; font-size: .8rem; text-transform: uppercase;
             letter-spacing: .06em; }
table { width: 100%; border-collapse: collapse; font-variant-numeric: tabular-nums; }
th { text-align: left; font-size: .75rem; text-transform: uppercase;
     letter-spacing: .07em; color: #7fa7c8; padding: .4rem .5rem;
     border-bottom: 1px solid #2b3a4a; }
td { padding: .45rem .5rem; border-bottom: 1px solid #1b2733; }
td.num { text-align: right; }
tr:hover td { background: #16212d; }
.bar { position: relative; height: 1.1rem; background: #1b2733; border-radius: 2px; }
.bar i { position: absolute; top: 0; bottom: 0; display: block; border-radius: 2px; }
.bar u { position: absolute; top: -2px; bottom: -2px; width: 1px; background: #4a6076; }
.band { position: absolute; top: 0; bottom: 0; background: #1f3324; }
.ok i { background: #5d9f3e; }
.watch i { background: #d58a24; }
.WARN i { background: #d94d3f; }
.mirror i { background: #4a6076; }
.pill { display: inline-block; padding: .05rem .45rem; border-radius: 999px;
        font-size: .72rem; font-weight: 700; letter-spacing: .04em; }
.pill.ok { background: #1f3324; color: #86c95a; }
.pill.watch { background: #35290f; color: #e0a53d; }
.pill.WARN { background: #3a1c18; color: #ef7a6c; }
.pill.mirror { background: #22303f; color: #9fb6cb; }
.pill.low { background: #35290f; color: #e0a53d; }
.pill.naval { background: #15293d; color: #6fa8dc; }
.notes { padding-left: 1.1rem; }
.notes li { margin: .4rem 0; color: #c2d3e2; }
.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }
figure { margin: 0; background: #16212d; border: 1px solid #23313f;
         border-radius: .5rem; padding: .75rem; overflow: hidden; }
figcaption { font: 600 .72rem/1.4 ui-monospace, Menlo, monospace; color: #8ba3ba;
             margin-bottom: .4rem; overflow-wrap: anywhere; }
svg { display: block; width: 100%; height: auto; }
.legend { font-size: .72rem; color: #8ba3ba; margin-top: .3rem; }
.legend b { font-weight: 700; }
.red { color: #ef7a6c; }
.blue { color: #6fa8dc; }
